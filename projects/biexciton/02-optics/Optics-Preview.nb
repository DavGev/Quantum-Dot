Cell["\<\
CONSEQUENCE: at zeroth order only ground -> X00 (and the ladder X00 -> \
XX0000, X01 -> XX0001, X10 -> XX0100, each adding a matching e-h pair) carry \
oscillator strength; ground -> X01 / X10 are dark. Any nonzero strength for \
the excited transitions in the final paper must come from the correlated \
wavefunctions -- the optics derivation has to evaluate dipole matrix elements \
over Psi = Psi0 F, not over Psi0.\
\>", "Text",
 CellChangeTimes->{
  3.993452099679859*^9},ExpressionUUID->"732c40ed-e7e3-9745-8f49-\
ab89cc66f7b8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["chi3 and absorption preview (placeholder response model)", "Section",ExpressionUUID->"97f0f42e-7729-d74b-8bb0-2a3638ad3f0a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"PREVIEW", " ", 
     RowBox[{"ONLY", ":", " ", 
      RowBox[{
       RowBox[{"standard", " ", "three"}], "-", 
       RowBox[{"level", " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"ground", " ", "/", " ", "X"}], " ", "/", " ", "XX"}], 
         ")"}], " ", "Lorentzian", " ", "response", "\n", "   ", "with", " ", 
        "unit", " ", "dipoles"}]}]}]}], ";", " ", 
    RowBox[{
     RowBox[{
     "the", " ", "real", " ", "formulas", " ", "come", " ", "from", " ", 
      "the", " ", "optics", " ", 
      RowBox[{"derivation", ".", "\n", "   ", "Ebind"}]}], " ", "=", " ", 
     RowBox[{
      RowBox[{"0", " ", "at", " ", "zeroth", " ", "order"}], " ", "->", " ", 
      RowBox[{
       RowBox[{"the", " ", "two"}], "-", 
       RowBox[{"photon", " ", 
        RowBox[{
         RowBox[{"chi3", " ", "~", " ", "1"}], "/", 
         RowBox[{"Ebind", "^", "2"}]}], " ", "is", " ", "singular"}]}]}]}], ";",
     "\n", "   ", 
    RowBox[{
     RowBox[{"ebindPh", " ", 
      RowBox[{"(", "meV", ")"}], " ", "is", " ", "a", " ", 
      RowBox[{"placeholder", " ", "--"}], " ", "replace", " ", "with", " ", 
      "2", "E", 
      RowBox[{"(", "X00", ")"}]}], " ", "-", " ", 
     RowBox[{"E", 
      RowBox[{"(", "XX0000", ")"}], " ", "from", "\n", "   ", "production"}], 
     "-", 
     RowBox[{
      RowBox[{"results", ".", "wxf"}], " ", "when", " ", 
      RowBox[{"available", "."}]}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"gam", " ", "=", " ", "0.5"}], ";"}], "      ", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"hbar", "*", "Gamma"}], ",", " ", "meV", ",", " ", 
     "phenomenological"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"ebindPh", " ", "=", " ", "1.0"}], ";"}], "  ", 
   RowBox[{"(*", " ", 
    RowBox[{"meV", ",", " ", 
     RowBox[{"placeholder", " ", "binding", " ", "energy"}]}], " ", "*)"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"chi3Preview", "[", 
       RowBox[{"a_", ",", " ", "c_"}], "]"}], "[", "hw_", "]"}], " ", ":=", 
     "\n", "  ", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"ex", " ", "=", " ", 
          RowBox[{
           RowBox[{"xMeV", "[", 
            RowBox[{"a", ",", " ", "c"}], "]"}], "[", 
           RowBox[{"0", ",", " ", "0"}], "]"}]}], ",", " ", "eb"}], "}"}], ",",
        "\n", "   ", 
       RowBox[{
        RowBox[{"eb", " ", "=", " ", 
         RowBox[{
          RowBox[{"2", " ", 
           RowBox[{
            RowBox[{"xMeV", "[", 
             RowBox[{"a", ",", " ", "c"}], "]"}], "[", 
            RowBox[{"0", ",", " ", "0"}], "]"}]}], " ", "-", " ", "ebindPh", 
          " ", "+", " ", 
          RowBox[{
           RowBox[{"xxMeV", "[", 
            RowBox[{"a", ",", " ", "c"}], "]"}], "[", 
           RowBox[{"0", ",", " ", "0", ",", " ", "0", ",", " ", "0"}], "]"}], 
          " ", "-", "\n", "     ", 
          RowBox[{"2", " ", 
           RowBox[{
            RowBox[{"xMeV", "[", 
             RowBox[{"a", ",", " ", "c"}], "]"}], "[", 
            RowBox[{"0", ",", " ", "0"}], "]"}]}]}]}], ";", "  ", 
        RowBox[{"(*", " ", 
         RowBox[{"=", " ", 
          RowBox[{
           RowBox[{"E", 
            RowBox[{"(", "XX", ")"}]}], " ", "-", " ", 
           RowBox[{"Ebind", " ", "placeholder", " ", "shift"}]}]}], " ", 
         "*)"}], "\n", "   ", 
        RowBox[{
         RowBox[{"1", "/", 
          RowBox[{"(", 
           RowBox[{"(", 
            RowBox[{"ex", " ", "-", " ", "hw", " ", "-", " ", 
             RowBox[{"I", " ", "gam"}]}], ")"}], ")"}]}], " ", "*", "\n", 
         "    ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"1", "/", 
            RowBox[{"(", 
             RowBox[{"(", 
              RowBox[{"eb", " ", "-", " ", 
               RowBox[{"2", " ", "hw"}], " ", "-", " ", 
               RowBox[{"I", " ", "gam"}]}], ")"}], ")"}]}], " ", "-", " ", 
           RowBox[{"1", "/", 
            RowBox[{"(", 
             RowBox[{"(", 
              RowBox[{"ex", " ", "-", " ", "hw", " ", "+", " ", 
               RowBox[{"I", " ", "gam"}]}], ")"}], ")"}]}]}], ")"}]}]}]}], 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"Re", "[", 
         RowBox[{
          RowBox[{"chi3Preview", "[", 
           RowBox[{"5.0", ",", " ", "c"}], "]"}], "[", "hw", "]"}], "]"}], 
        " ", "/.", " ", 
        RowBox[{"c", " ", "->", " ", "0.5"}]}], ",", "\n", "  ", 
       RowBox[{
        RowBox[{"Im", "[", 
         RowBox[{
          RowBox[{"chi3Preview", "[", 
           RowBox[{"5.0", ",", " ", "c"}], "]"}], "[", "hw", "]"}], "]"}], 
        " ", "/.", " ", 
        RowBox[{"c", " ", "->", " ", "0.5"}]}]}], "}"}], ",", "\n", " ", 
     RowBox[{"{", 
      RowBox[{"hw", ",", " ", "30", ",", " ", "90"}], "}"}], ",", " ", 
     RowBox[{"Frame", " ", "->", " ", "True"}], ",", " ", 
     RowBox[{"PlotRange", " ", "->", " ", "All"}], ",", "\n", " ", 
     RowBox[{"FrameLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<\[HBar]\[Omega] (meV)\>\"", ",", 
        " ", "\"\<\[Chi]3 (arb.)\>\""}], "}"}]}], ",", "\n", " ", 
     RowBox[{"PlotLegends", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Re\>\"", ",", " ", "\"\<Im\>\""}], "}"}]}], ",", "\n", 
     " ", 
     RowBox[{
     "PlotLabel", " ", "->", 
      " ", "\"\<one-photon region, a=5, c=0.5 (placeholder model)\>\""}], ",",
      "\n", " ", 
     RowBox[{"ImageSize", " ", "->", " ", "450"}]}], "]"}]}]}]], "Input",
