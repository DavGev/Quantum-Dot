Cell["Zeroth-order energies", "Section",ExpressionUUID->"fcfe5d11-90cd-744d-9c7f-2014587a0622"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"particle", " ", "levels"}], ";", " ", 
    RowBox[{
     RowBox[{"lvl", "[", "2", "]"}], " ", "shown", " ", "for", " ", "the", " ",
      "extended", " ", "diagram", " ", "only"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"lvl", "[", "0", "]"}], " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "0", ",", " ", "0"}], "}"}]}], ";", " ", 
    RowBox[{
     RowBox[{"lvl", "[", "1", "]"}], " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "0", ",", " ", "1"}], "}"}]}], ";", " ", 
    RowBox[{
     RowBox[{"lvl", "[", "2", "]"}], " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{"1", ",", " ", "1", ",", " ", "0"}], "}"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"e0X", "[", 
       RowBox[{"a_", ",", " ", "c_"}], "]"}], "[", 
      RowBox[{"i_", ",", " ", "j_"}], "]"}], " ", ":=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Ee", "[", 
        RowBox[{"a", ",", " ", "c", ",", " ", "0"}], "]"}], " ", "@@", " ", 
       RowBox[{"lvl", "[", "i", "]"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"Eh", "[", 
        RowBox[{"a", ",", " ", "c", ",", " ", "0"}], "]"}], " ", "@@", " ", 
       RowBox[{"lvl", "[", "j", "]"}]}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"e0XX", "[", 
       RowBox[{"a_", ",", " ", "c_"}], "]"}], "[", 
      RowBox[{"i_", ",", " ", "j_", ",", " ", "k_", ",", " ", "l_"}], "]"}], 
     " ", ":=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"Ee", "[", 
        RowBox[{"a", ",", " ", "c", ",", " ", "0"}], "]"}], " ", "@@", " ", 
       RowBox[{"lvl", "[", "i", "]"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"Ee", "[", 
        RowBox[{"a", ",", " ", "c", ",", " ", "0"}], "]"}], " ", "@@", " ", 
       RowBox[{"lvl", "[", "j", "]"}]}], " ", "+", "\n", "  ", 
      RowBox[{
       RowBox[{"Eh", "[", 
        RowBox[{"a", ",", " ", "c", ",", " ", "0"}], "]"}], " ", "@@", " ", 
       RowBox[{"lvl", "[", "k", "]"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"Eh", "[", 
        RowBox[{"a", ",", " ", "c", ",", " ", "0"}], "]"}], " ", "@@", " ", 
       RowBox[{"lvl", "[", "l", "]"}]}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"meV", " ", "throughout", " ", "the", " ", "plots"}], " ", "*)"}],
    "\n", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"xMeV", "[", 
       RowBox[{"a_", ",", " ", "c_"}], "]"}], "[", 
      RowBox[{"i_", ",", " ", "j_"}], "]"}], " ", ":=", " ", 
     RowBox[{"ER2meV", " ", 
      RowBox[{
       RowBox[{"e0X", "[", 
        RowBox[{"a", ",", " ", "c"}], "]"}], "[", 
       RowBox[{"i", ",", " ", "j"}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"xxMeV", "[", 
       RowBox[{"a_", ",", " ", "c_"}], "]"}], "[", 
      RowBox[{"i_", ",", " ", "j_", ",", " ", "k_", ",", " ", "l_"}], "]"}], 
     " ", ":=", " ", 
     RowBox[{"ER2meV", " ", 
      RowBox[{
       RowBox[{"e0XX", "[", 
        RowBox[{"a", ",", " ", "c"}], "]"}], "[", 
       RowBox[{"i", ",", " ", "j", ",", " ", "k", ",", " ", "l"}], "]"}]}]}], 
    ";"}]}]}]], "Input",
