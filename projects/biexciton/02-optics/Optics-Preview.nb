Cell["Figure 2 analog: transition scheme at the base geometry", "Section",ExpressionUUID->"7106213e-2c1d-e443-abe6-54de4e2815b2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "the", " ", "three", " ", "exciton", " ", "and", " ", "three", " ", 
     "biexciton", " ", "states", " ", "of", " ", "the", " ", 
     RowBox[{"paper", "'"}], "s", " ", "scheme"}], ";", "\n", "   ", 
    RowBox[{
     RowBox[{"at", " ", "zeroth", " ", "order", " ", "E", 
