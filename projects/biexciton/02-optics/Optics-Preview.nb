Cell[CellGroupData[{

Cell["Dipoles and selection rules at zeroth order", "Section",ExpressionUUID->"f7b8a91b-5fcf-2e4f-9b86-eb744aeee5d7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"interband", " ", 
        RowBox[{"dipole", " ", "~"}]}], " ", "<", "psi_e"}], "|", 
      RowBox[{"psi_h", ">"}]}], ":", " ", 
     RowBox[{
     "electron", " ", "and", " ", "hole", " ", "orbitals", " ", "come", " ", 
      "from", "\n", "   ", "the", " ", "SAME", " ", "omega00", " ", 
      "basis"}]}], ",", " ", 
    RowBox[{
    "so", " ", "the", " ", "overlap", " ", "is", " ", "exactly", " ", 
     "delta_", 
     RowBox[{
      RowBox[{"(", "state", ")"}], ".", "\n", "   ", "Numeric"}], " ", 
     "confirmation", " ", "via", " ", "the", " ", "radial", " ", 
     RowBox[{"overlap", ":"}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"radialOverlap", "[", 
       RowBox[{"a_", ",", " ", "c_"}], "]"}], "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"n1_", ",", " ", "m1_"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"n2_", ",", " ", "m2_"}], "}"}]}], "]"}], " ", ":=", "\n", 
     "  ", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"m1", " ", "=!=", " ", "m2"}], ",", " ", "0.", ",", "\n", 
       "   ", 
       RowBox[{"2", " ", "Pi", " ", 
        RowBox[{"NIntegrate", "[", "\n", "     ", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"\[Psi]r", "[", 
             RowBox[{"n1", ",", " ", "m1"}], "]"}], "[", 
            RowBox[{
             RowBox[{"\[HBar]\[Omega]00", "[", 
              RowBox[{"a", ",", " ", "c"}], "]"}], ",", " ", "r"}], "]"}], " ", 
           RowBox[{
            RowBox[{"\[Psi]r", "[", 
             RowBox[{"n2", ",", " ", "m2"}], "]"}], "[", 
            RowBox[{
             RowBox[{"\[HBar]\[Omega]00", "[", 
              RowBox[{"a", ",", " ", "c"}], "]"}], ",", " ", "r"}], "]"}], " ",
            "r"}], ",", "\n", "     ", 
          RowBox[{"{", 
           RowBox[{"r", ",", " ", "0", ",", " ", 
            RowBox[{"0.9", " ", "a", " ", "5"}]}], "}"}]}], "]"}]}]}], 
      "]"}]}], ";"}], "\n", 
   RowBox[{"Dataset", "[", 
    RowBox[{"{", "\n", "  ", 
     RowBox[{
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<pair\>\"", " ", "->", " ", "\"\<e(0,0)-h(0,0)\>\""}], ",",
         "\n", "   ", 
        RowBox[{"\"\<overlap\>\"", " ", "->", " ", 
         RowBox[{
          RowBox[{"radialOverlap", "[", 
           RowBox[{"5.0", ",", " ", "0.5"}], "]"}], "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0", ",", " ", "0"}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"0", ",", " ", "0"}], "}"}]}], "]"}]}]}], "|>"}], ",", 
      "\n", "  ", 
