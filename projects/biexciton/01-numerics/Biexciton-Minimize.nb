Notebook[{

Cell[CellGroupData[{
Cell["Bi-exciton \[Dash] Capped Minimization & Convergence Diagnostics", \
"Title",ExpressionUUID->"b5a29955-1ee9-554b-b269-1de16e896f43"],

Cell["\<\
Runs the variational minimization with a hard iteration cap and logs the \
optimizer's progress, so it can no longer run unbounded. The key output is \
the convergence graph (best objective vs iteration). Start with the small \
diagnostic settings below to see the convergence behaviour in ~a minute, then \
raise bxMaxPoints and maxIter for a production run. Evaluate top to bottom.\
\>", "Text",ExpressionUUID->"8bcb47bc-54c5-284e-b10e-0ee360d28546"],

Cell[CellGroupData[{

Cell["Load definitions", "Section",ExpressionUUID->"0de868a6-7596-e849-9e07-d2667a695027"],

Cell["\<\
dir = NotebookDirectory[];
Get[FileNameJoin[{ParentDirectory[dir, 3], \"shared\", \"numerics\", \
\"definitions.wl\"}]];
Get[FileNameJoin[{dir, \"mixed-correlation.wl\"}]];
Get[FileNameJoin[{dir, \"mixed-density.wl\"}]];
Get[FileNameJoin[{dir, \"mixed-integrals.wl\"}]];
Get[FileNameJoin[{dir, \"mixed-diagnostics.wl\"}]];\
\>", "Input",
 CellLabel->"In[63]:=",ExpressionUUID->"f45c997b-8024-da4c-9ce1-c690e0a462b3"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Configuration and run settings", "Section",ExpressionUUID->"2e2bf5e0-db79-5d47-93e6-022b61393150"],

Cell["\<\
(* geometry + state configuration *)
a = 4.0;
c = 0.4;
bxElectronStates = {{1, 0, 0}, {1, 0, 0}};
bxHoleStates = {{1, 0, 0}, {1, 0, 0}};
bxEtaE = 1;
bxEtaH = 1;\
\>", "Input",
 CellLabel->"In[69]:=",ExpressionUUID->"290e5f10-165c-5a41-bc16-f2a19351db32"],

Cell["\<\
(* diagnostic settings: start small to see convergence fast, then scale up *)
bxMaxPoints = 20000;   (* Monte-Carlo budget per integral; production ~ \
2*10^5 *)
maxIter = 8;           (* NelderMead iteration cap; raise once the curve \
looks sane *)\
\>", "Input",
 CellLabel->"In[76]:=",ExpressionUUID->"df388b7f-fe94-5742-9e8f-6442242367a8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Capped minimization", "Section",ExpressionUUID->"70faefbd-c97e-bf44-a214-4cc5e0afa39e"],

Cell[CellGroupData[{

Cell["result = minimizeBiexcitonTracked[a, c, maxIter]", "Input",
 CellLabel->"In[79]:=",ExpressionUUID->"7d5e728a-f4a8-4949-8abb-6f3db8d7697a"],

Cell[BoxData["$Aborted"], "Output",
 CellChangeTimes->{3.992075349160631*^9},
 CellLabel->"Out[79]=",ExpressionUUID->"f1f77e0f-4ee5-f843-9606-f935e2ec8fca"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Convergence diagnostics", "Section",ExpressionUUID->"52d808b1-21c3-fb4b-9a7e-8065bcdfafb8"],

Cell["\<\
(* best objective vs iteration -- the convergence graph *)
bxConvergencePlot[]\
\>", "Input",ExpressionUUID->"d91ba5e3-6eb5-1d4a-b387-f60625244527"],

Cell["\<\
(* raw objective at each evaluation -- shows Monte-Carlo scatter *)
bxObjectivePlot[]\
\>", "Input",ExpressionUUID->"04643a43-5498-214b-b1f0-e823b6c00275"],

Cell["bxOptReport[]", "Input",ExpressionUUID->"80c93276-ba7a-8145-aafd-ad2a45602b80"],

