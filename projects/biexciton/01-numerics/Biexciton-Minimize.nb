 RowBox[{
  RowBox[{"Get", "[", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{"dir", ",", "\"\<mixed-diagnostics.wl\>\""}], "}"}], "]"}], 
   "]"}], ";"}]], "Input",
