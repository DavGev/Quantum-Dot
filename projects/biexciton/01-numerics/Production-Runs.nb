(* http://www.wolfram.com/nb *)

Notebook[{

Cell[CellGroupData[{
Cell["Production Runs \[Dash] Exciton & Biexciton Energies", "Title"],

Cell["\<\
Final energy evaluations for the paper (semi-ellipsoidal analog of the \
reference: Non-Linear Optical Properties of Biexciton in Ellipsoidal Quantum \
Dot, Nanomaterials 12, 1412).

States (see the Optical Selection Rules note): the bright diamond -- \
excitons X00 and X11 = e{1,0,1} x h{1,0,-1}, biexcitons XX0000, XX0101 \
(both pairs distinct; remaining eta combinations resolved at the base \
geometry via runXX0101All) and XX1111 -- plus the cheap dark excitons \
X01/X10 at every geometry, and the island biexcitons XX0010 = |0001> and \
XX1000 = |0100> at the two diagram geometries only (runIslands).

Geometries are defined in nm (paper-style values) and converted via the \
material rB: c = 6/7/8 nm at a = 50 nm (scan + base), c = 10 nm (second \
energy-diagram set), a = 40/60 nm at c = 6 nm (large-semiaxis dependence). \
The c grid is shifted up from the reference's 5 nm so the hard-wall axial \
confinement stays well below realistic band offsets. The completed legacy \
geometries (5, 0.5) and (5, 0.55) rB remain in the result store as extra \
c-scan points.

Every run follows the validated protocol from the Computational Design Log: \
minimize (warm-started via the archive chain: exact configuration, else \
nearest geometry with identical states), re-evaluate the energy at the \
optimum with the production budget, stamp with the quadrature identity \
checks. Results are checkpointed to production-results.wxf after every run, \
so the notebook can be aborted and resumed freely; completed runs are \
skipped on re-evaluation. Distinct-orbital biexciton configurations \
automatically get the larger budgets.

Evaluate top to bottom; the per-geometry cells are independent and can be \
run in any order or on different days.\
\>", "Text"],

Cell[CellGroupData[{

Cell["Load both frameworks", "Section"],

Cell["\<\
dir = NotebookDirectory[];
Get[FileNameJoin[{ParentDirectory[dir, 3], \"shared\", \"numerics\", \
\"definitions.wl\"}]];
exDir = FileNameJoin[{ParentDirectory[dir, 2], \"exciton\", \
\"01-numerics\"}];
Get[FileNameJoin[{exDir, \"mixed-correlation.wl\"}]];
Get[FileNameJoin[{exDir, \"mixed-density.wl\"}]];
Get[FileNameJoin[{exDir, \"mixed-integrals.wl\"}]];
Get[FileNameJoin[{dir, \"mixed-correlation.wl\"}]];
Get[FileNameJoin[{dir, \"mixed-density.wl\"}]];
Get[FileNameJoin[{dir, \"mixed-integrals.wl\"}]];\
\>", "Input"],

Cell["\<\
(* smoke test: exact identity, must be ~1 to ~0.1% *)
normExciton[5.0, 0.5, 0.]\
\>", "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Result store and protocol runners", "Section"],

Cell["\<\
(* checkpointed result store; completed runs are skipped *)
prodFile = FileNameJoin[{dir, \"production-results.wxf\"}];
prodResults = If[FileExistsQ[prodFile], Import[prodFile, \"WXF\"], <||>];
prodSave[] := Export[prodFile, prodResults, \"WXF\"];
prodKey[label_, aa_, cc_] :=
  StringJoin[label, \"|a=\", ToString[aa], \"|c=\", ToString[cc]];\
\>", "Input"],

Cell["\<\
(* exciton protocol: minimize (fast, 5-dim integrals) -> re-evaluate at the
   optimum with 10^6 points -> identity stamp. *)
runExciton[label_, aa_, cc_, eState_, hState_] :=
  Module[{key = prodKey[label, aa, cc], opt, al, res},
   If[KeyExistsQ[prodResults, key], Return[prodResults[key]]];
   exElectronState = eState; exHoleState = hState;
   minimizeExciton[aa, cc];
   opt = exOptimum[]; al = opt[\"params\"][[1]];
   res = Block[{exMaxPoints = 10^6},
     Append[totalEnergyExciton[aa, cc, al],
      <|\"alpha\" -> al, \"label\" -> label,
        \"check\" -> exQuadratureCheck[aa, cc, al]|>]];
   prodResults[key] = res; prodSave[]; res];\
\>", "Input"],

Cell["\<\
(* biexciton protocol: distinct-orbital configurations get 4-5x budgets
   (see the Design Log validation table). Warm starts come from the .wl
   archive chain; pass an explicit start list to override. *)
runBiexciton[label_, aa_, cc_, eStates_, hStates_, etaE_, etaH_,
   start_: Automatic] :=
  Module[{key = prodKey[label, aa, cc], distinct, minPts, finPts, opt, p, res},
   If[KeyExistsQ[prodResults, key], Return[prodResults[key]]];
   bxElectronStates = eStates; bxHoleStates = hStates;
   bxEtaE = etaE; bxEtaH = etaH;
   distinct = (eStates[[1]] =!= eStates[[2]]) || (hStates[[1]] =!= \
hStates[[2]]);
   minPts = If[distinct, 4*10^5, 2*10^5];
   finPts = If[distinct, 4*10^6, 10^6];
   Block[{bxMaxPoints = minPts}, minimizeBiexciton[aa, cc, 50, start]];
   opt = bxOptimum[]; p = opt[\"params\"];
   res = Block[{bxMaxPoints = finPts, bxPrecisionGoal = 3},
     Append[totalEnergyBiexciton[aa, cc, Sequence @@ p],
      <|\"params\" -> p, \"label\" -> label,
        \"evaluations\" -> opt[\"evaluations\"],
        \"check\" -> bxQuadratureCheckAll[aa, cc, Sequence @@ p]|>]];
   prodResults[key] = res; prodSave[]; res];\
\>", "Input"],

Cell["\<\
(* worst identity spread of a stored run -- quick health readout *)
worstSpread[res_] := Max[Cases[res[\"check\"],
    KeyValuePattern[\"relSpread\" -> s_] :> s, {1}]];\
\>", "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Configurations", "Section"],

Cell["\<\
(* particle levels: 0 = ground, +/-1 = first in-plane excitations *)
lvl[0] = {1, 0, 0}; lvl[1] = {1, 0, 1}; lvl[-1] = {1, 0, -1};

(* states run at EVERY geometry: the bright diamond
   (g <-> X00/X11 <-> XX0000/XX0101/XX1111) plus the cheap dark excitons.
   XX0101 here is the eta = (+,+) representative. *)
runAllStates[aa_, cc_] :=
  (runExciton[\"X00\", aa, cc, lvl[0], lvl[0]];
   runExciton[\"X01\", aa, cc, lvl[0], lvl[1]];
   runExciton[\"X10\", aa, cc, lvl[1], lvl[0]];
   runExciton[\"X11\", aa, cc, lvl[1], lvl[-1]];
   runBiexciton[\"XX0000\", aa, cc,
    {lvl[0], lvl[0]}, {lvl[0], lvl[0]}, 1, 1];
   runBiexciton[\"XX1111\", aa, cc,
    {lvl[1], lvl[1]}, {lvl[-1], lvl[-1]}, 1, 1];
   runBiexciton[\"XX0101pp\", aa, cc,
    {lvl[0], lvl[1]}, {lvl[0], lvl[-1]}, 1, 1];
   Dataset[KeySelect[prodResults,
     StringContainsQ[#, prodKey[\"\", aa, cc]] &]]);

(* base-geometry extras: remaining exchange combinations of XX0101;
   E(eta = -1) - E(eta = +1) is the exchange splitting *)
runXX0101All[aa_, cc_] :=
  (runBiexciton[\"XX0101pm\", aa, cc,
    {lvl[0], lvl[1]}, {lvl[0], lvl[-1]}, 1, -1];
   runBiexciton[\"XX0101mp\", aa, cc,
    {lvl[0], lvl[1]}, {lvl[0], lvl[-1]}, -1, 1];
   runBiexciton[\"XX0101mm\", aa, cc,
    {lvl[0], lvl[1]}, {lvl[0], lvl[-1]}, -1, -1];
   Dataset[KeySelect[prodResults,
     StringContainsQ[#, \"XX0101\"] &&
       StringContainsQ[#, prodKey[\"\", aa, cc]] &]]);

(* radiatively disconnected islands (XX0010 = |0001>, XX1000 = |0100>):
   energy diagram + cascade discussion -- diagram geometries only *)
runIslands[aa_, cc_] :=
  (runBiexciton[\"XX0010\", aa, cc,
    {lvl[0], lvl[0]}, {lvl[0], lvl[1]}, 1, 1];
   runBiexciton[\"XX1000\", aa, cc,
    {lvl[0], lvl[1]}, {lvl[0], lvl[0]}, 1, 1];
   Dataset[KeySelect[prodResults,
     StringContainsQ[#, prodKey[\"\", aa, cc]] &]]);

(* geometry grid in nm, converted to rB via the material Bohr radius *)
nmToRB = 10.^-9/rB;
geomNm = {{50, 6}, {50, 7}, {50, 8}, {50, 10}, {40, 6}, {60, 6}};
geometries = nmToRB geomNm;\
\>", "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Production runs (resumable; P1 first, then the grid)", "Section"],

Cell["\<\
(* P1: base geometry (50 nm, 6 nm) -- everything *)
runAllStates @@ geometries[[1]]\
\>", "Input"],

Cell["\<\
runXX0101All @@ geometries[[1]]
runIslands @@ geometries[[1]]\
\>", "Input"],

Cell["\<\
(* P2: the grid *)
runAllStates @@ geometries[[2]]  (* 50 nm, 7 nm *)\
\>", "Input"],

Cell["runAllStates @@ geometries[[3]]  (* 50 nm, 8 nm *)", "Input"],

Cell["\<\
(* P3: second diagram set, islands included *)
runAllStates @@ geometries[[4]]  (* 50 nm, 10 nm *)
runIslands @@ geometries[[4]]\
\>", "Input"],

Cell["runAllStates @@ geometries[[5]]  (* 40 nm, 6 nm *)", "Input"],

Cell["runAllStates @@ geometries[[6]]  (* 60 nm, 6 nm *)", "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Summary: energies, binding, diamond transitions", "Section"],

Cell["\<\
(* one row per geometry (Ry; multiply by ER2meV for meV). Missing-tolerant:
   island and eta-combination columns fill in only where those runs exist. *)
summaryRows = Module[{get, d},
   get[l_, aa_, cc_] :=
    With[{r = Lookup[prodResults, prodKey[l, aa, cc]]},
     If[AssociationQ[r], r[\"total\"], Missing[\"NotRun\"]]];
   d[x_, y_] := If[NumericQ[x] && NumericQ[y], x - y, Missing[\"NotRun\"]];
   Table[Module[{aa = g[[1]], cc = g[[2]], x00, x11, b0, b01, b11},
     x00 = get[\"X00\", aa, cc]; x11 = get[\"X11\", aa, cc];
     b0 = get[\"XX0000\", aa, cc]; b01 = get[\"XX0101pp\", aa, cc];
     b11 = get[\"XX1111\", aa, cc];
     <|\"a\" -> aa, \"c\" -> cc,
       \"E(X00)\" -> x00, \"E(X01)\" -> get[\"X01\", aa, cc],
       \"E(X10)\" -> get[\"X10\", aa, cc], \"E(X11)\" -> x11,
       \"E(XX0000)\" -> b0, \"E(XX0101pp)\" -> b01, \"E(XX1111)\" -> b11,
       \"E(XX0010)\" -> get[\"XX0010\", aa, cc],
       \"E(XX1000)\" -> get[\"XX1000\", aa, cc],
       \"Ebind(XX0000)\" -> d[If[NumericQ[x00], 2 x00, x00], b0],
       \"T(XX0000->X00)\" -> d[b0, x00],
       \"T(XX0101->X00)\" -> d[b01, x00],
       \"T(XX0101->X11)\" -> d[b01, x11],
       \"T(XX1111->X11)\" -> d[b11, x11]|>],
    {g, geometries}]];
Dataset[summaryRows]\
\>", "Input"],

Cell["\<\
(* eta fine structure of XX0101 at the base geometry *)
Module[{get},
 get[l_] := With[{r = Lookup[prodResults, prodKey[l, Sequence @@ \
geometries[[1]]]]},
   If[AssociationQ[r], r[\"total\"], Missing[\"NotRun\"]]];
 Dataset[<|\"pp\" -> get[\"XX0101pp\"], \"pm\" -> get[\"XX0101pm\"],
   \"mp\" -> get[\"XX0101mp\"], \"mm\" -> get[\"XX0101mm\"]|>]]\
\>", "Input"],

Cell["\<\
(* quadrature health of every stored run: worst identity spread each *)
Dataset[worstSpread /@ prodResults]\
\>", "Input"],

Cell["\<\
(* meV table + CSV export for the plotting notebook (a, c stay in rB) *)
summaryMeV = Map[
   Join[KeyTake[#, {\"a\", \"c\"}],
     Map[If[NumericQ[#], # ER2meV, #] &, KeyDrop[#, {\"a\", \"c\"}]]] &,
   summaryRows];
Export[FileNameJoin[{dir, \"production-summary-meV.csv\"}],
  Prepend[Values /@ summaryMeV, Keys[First[summaryMeV]]]];
Dataset[summaryMeV]\
\>", "Input"]
}, Open  ]]
}, Open  ]]
}]
