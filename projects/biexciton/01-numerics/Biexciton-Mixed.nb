      RowBox[{"w0", "=", 
       RowBox[{
        RowBox[{"psiWeightBiexcitonMixed", "[", 
         RowBox[{"a", ",", "c", ",", "om"}], "]"}], "[", 
        RowBox[{
        "u1", ",", "r1", ",", "t1", ",", "u2", ",", "r2", ",", "t2", ",", 
         "ua", ",", "ra", ",", "ub", ",", "rb", ",", "tb"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"wSwap", "=", 
