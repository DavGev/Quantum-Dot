Notebook[{

Cell[CellGroupData[{
Cell["Bi-exciton \[Dash] Mixed Single-Particle States", "Title",ExpressionUUID->"7d9a1a19-58b5-c44e-8b38-44759b3cae0f"],

Cell["\<\
Variational biexciton energy where the four particles may occupy different \
single-particle states. Reuses the correlation factors and kinetic kernels of \
Biexciton.nb; the only generalized piece is the antisymmetrized density \
psiWeightBiexcitonMixed. Configure the states in the cell below, then \
evaluate the checks top to bottom.\
\>", "Text",ExpressionUUID->"775be845-1ecb-0946-9f4b-34fa8285be43"],

Cell[CellGroupData[{

Cell["Load definitions", "Section",ExpressionUUID->"6f04266b-53c3-d543-9389-b581d939204a"],

Cell["\<\
dir = NotebookDirectory[];
Get[FileNameJoin[{ParentDirectory[dir, 3], \"shared\", \"numerics\", \
\"definitions.wl\"}]];
Get[FileNameJoin[{dir, \"mixed-correlation.wl\"}]];
Get[FileNameJoin[{dir, \"mixed-density.wl\"}]];|
Get[FileNameJoin[{dir, \"mixed-integrals.wl\"}]];\
\>", "Input",
 CellChangeTimes->{3.992598951733444*^9},
 CellLabel->
  "In[112]:=",ExpressionUUID->"952f832b-4149-8c4b-b212-7ce1792c0876"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Parameters and state configuration", "Section",ExpressionUUID->"8ef07e9d-f568-fe43-96cf-78c7d3840d27"],

Cell["\<\
(* dome geometry, in effective Bohr radii (c/a \[LessLess] 1) *)
a = 5.0;
c = 0.5;\
\>", "Input",
 CellChangeTimes->{{3.9925117910767326`*^9, 3.992511792789961*^9}, {
  3.9925120234114456`*^9, 
  3.992512026973013*^9}},ExpressionUUID->"a5cc23fb-9305-1e4b-b83e-\
8b312ad8d966"],

Cell["\<\
(* each state is {\[Nu], n, m}; \[Eta] = +1 singlet (spatially symmetric), -1 \
triplet *)
bxElectronStates = {{1, 0, 0}, {1, 0, 0}};
bxHoleStates = {{1, 0, 0}, {1, 0, 0}};
bxEtaE = 1;
bxEtaH = 1;\
\>", "Input",
 CellLabel->"In[12]:=",ExpressionUUID->"dce32a0e-246d-2a4f-aae8-4d4e60eab48b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Sanity checks", "Section",ExpressionUUID->"02a6354c-af52-3743-9fb1-3d9b81496cbf"],

Cell[CellGroupData[{

Cell["\<\
(* 1. density is positive and finite at a sample point *)
psiWeightBiexcitonMixed[a, c, \[HBar]\[Omega]00[a, c]][0.2, 1.0, 0.3, 0.4, \
1.2, 0.7, 0.3, 0.9, 0.0, 0.5, 1.1]\
\>", "Input",
 CellLabel->"In[17]:=",ExpressionUUID->"afb390e8-3993-6848-8b4e-656c3a1ddc5b"],

Cell[BoxData["0.`"], "Output",
 CellChangeTimes->{3.9909873292403145`*^9, 3.9920836474915943`*^9, 
  3.9920848793274155`*^9, 3.992511060862499*^9, 3.9925118041384315`*^9},
 CellLabel->"Out[18]=",ExpressionUUID->"a1bcd394-1fd9-fb45-a93c-995f14bfd6d6"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
(* 2. each integral returns a finite number (ground-state config) *)
{AbsoluteTiming[normDirectBiexciton[a, c, 1.0, 1.0, 0.0, 1.0]],
 AbsoluteTiming[normCrossBiexciton[a, c, 1.0, 1.0, 0.0, 1.0]]}\
\>", "Input",
 CellChangeTimes->{{3.9925119843883266`*^9, 3.9925120032914143`*^9}},
 CellLabel->"In[23]:=",ExpressionUUID->"c7e87e0f-2186-b048-b474-aa29067bbd8c"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"3.2299532`", ",", "0.000014989362440102958`"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"2.9656554`", ",", "0.000014989362440102958`"}], "}"}]}], 
  "}"}]], "Output",
 CellChangeTimes->{3.990987306341625*^9, 3.9920836643275223`*^9, 
  3.9925110911800137`*^9, 3.9925118169837704`*^9, 3.992512043608452*^9},
 CellLabel->"Out[24]=",ExpressionUUID->"4347dbde-9e20-b645-b813-64e939c7dffd"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
(* 3. full energy correction, ground-state config.
   With all four in {1,0,0} this must equal the original Biexciton.nb result. \
*)
AbsoluteTiming[energyCorrectionBiexcitonQuiet[a, c, 1.0, 1.0, 0.0, 1.0]]\
\>", "Input",
 CellChangeTimes->{{3.992512041466301*^9, 3.992512043250889*^9}},
 CellLabel->"In[25]:=",ExpressionUUID->"253cf55a-4aec-274c-b659-9dbb6f83540e"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"161.1980812`", ",", 
   RowBox[{"-", "1.9127841723725674`"}]}], "}"}]], "Output",
 CellChangeTimes->{3.990987439005703*^9, 3.9920838412101746`*^9, 
  3.992512025453287*^9, 3.992512209370989*^9},
 CellLabel->"Out[26]=",ExpressionUUID->"d779ce73-03c1-1c46-8cb8-918ffe7f9206"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
(* 4. excited config: both electrons in the first in-plane excited orbital \
{1,0,1} *)
bxElectronStates = {{1, 0, 1}, {1, 0, 1}};
AbsoluteTiming[energyCorrectionBiexcitonQuiet[a, c, 1.0, 1.0, 0.0, 1.0]]\
\>", "Input",
 CellChangeTimes->{{3.9925121072653637`*^9, 3.992512109189127*^9}},
 CellLabel->"In[27]:=",ExpressionUUID->"fb10a93b-b48d-6243-b3dc-feec3b5d5117"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"8.2916085`", ",", 
   RowBox[{"-", "8.175401249288063`"}]}], "}"}]], "Output",
 CellChangeTimes->{3.9909875244955063`*^9, 3.9920840949046173`*^9, 
  3.992512218033596*^9},
 CellLabel->"Out[29]=",ExpressionUUID->"1a615c13-326b-d24d-b3f8-b1930c8e8779"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
(* 5. distinct electron orbitals (exchange/interference active); singlet vs \
triplet *)
bxElectronStates = {{1, 0, 0}, {1, 0, 1}};
bxEtaE = 1;
AbsoluteTiming[energyCorrectionBiexcitonQuiet[a, c, 1.0, 1.0, 0.0, 1.0]]\
\>", "Input",
 CellChangeTimes->{{3.99251228827355*^9, 3.992512290443926*^9}},
 CellLabel->"In[31]:=",ExpressionUUID->"d66bf8be-7cb6-e04e-9547-a4576e2a56f7"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"122.4642164`", ",", 
   RowBox[{"-", "5.341368434868934`"}]}], "}"}]], "Output",
 CellChangeTimes->{3.9909875592713585`*^9, 3.9920842123425922`*^9, 
  3.992512420652996*^9},
 CellLabel->"Out[34]=",ExpressionUUID->"3086ac6c-34d1-554b-a334-540c9d6e9556"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
(* 6. variational minimum for the current configuration (heavier) *)
bxElectronStates = {{1, 0, 0}, {1, 0, 0}};
AbsoluteTiming[minimizeBiexciton[a, c]]\
\>", "Input",
 CellChangeTimes->{{3.992512602051937*^9, 3.9925126055044994`*^9}, {
  3.9925126473215675`*^9, 3.9925126492082634`*^9}, {3.9925971334756927`*^9, 
  3.992597136033451*^9}},
 CellLabel->
  "In[105]:=",ExpressionUUID->"12876773-322f-574d-b265-30811328e3ea"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"48262.9400434`", ",", "$Aborted"}], "}"}]], "Output",
 CellChangeTimes->{3.991044137598646*^9, 3.9920847844492874`*^9, 
  3.992094202183651*^9, 3.9925130191936455`*^9, 3.992518130405653*^9, 
  3.9925183441824055`*^9, 3.992518842585449*^9, 3.992668417019184*^9},
 CellLabel->
  "Out[107]=",ExpressionUUID->"598c20bb-e696-5842-a3ca-d535ef0eaa51"]
}, Open  ]],

